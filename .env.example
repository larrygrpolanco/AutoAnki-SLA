# AutoAnki Environment Configuration
# Copy this file to .env and fill in your API keys

# Required: OpenAI API Key for LLM and TTS generation
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Optional: OpenAI model selection (defaults to gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: TTS model (defaults to gpt-4o-mini-tts)
# OPENAI_TTS_MODEL=gpt-4o-mini-tts

# Optional: TTS voice selection (alloy, echo, fable, onyx, nova, shimmer)
# Defaults to 'alloy' - a balanced, neutral voice
# OPENAI_TTS_VOICE=alloy

# Optional: Request delay between TTS calls (in seconds)
# Prevents rate limiting. Default: 1.0
# TTS_DELAY=1.0
