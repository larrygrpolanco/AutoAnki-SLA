# AutoAnki Environment Configuration
# Copy this file to .env and fill in your API keys

# Required: OpenAI API Key for LLM and TTS generation
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Optional: OpenAI model selection (defaults to gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: TTS model (defaults to gpt-4o-mini-tts — supports language accent instructions)
# OPENAI_TTS_MODEL=gpt-4o-mini-tts

# Optional: TTS voice selection (alloy, ash, ballad, coral, echo, fable, nova, onyx, sage, shimmer, verse)
# Defaults to 'coral' - works well across languages
# OPENAI_TTS_VOICE=coral

# Optional: Request delay between TTS calls (in seconds)
# Prevents rate limiting. Default: 1.0
# TTS_DELAY=1.0

# Optional: Target language for flashcard generation
# If not set, AutoAnki will prompt you at startup each run.
# TARGET_LANGUAGE=Korean
